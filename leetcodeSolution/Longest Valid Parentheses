class Solution {
    public int longestValidParentheses(String s) {
     Stack<Integer> p= new Stack<>();
     p.push(-1);
     int max=0;
     for(int i=0;i<s.length();i++){
       if(s.charAt(i)=='('){
        p.push(i);
       }
       else{
        p.pop();
        if(p.isEmpty()){
            p.push(i);
        }else{
            int l=p.peek();
                 max=Math.max(max,i-l);
        }
               }
     } 
     return max;
    }
}
